---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';

const lang = 'en' as const;
---

<BaseLayout title="Thank you | WAMOCON GmbH" description="Thank you for your message." lang={lang}>
  <section class="section thanks">
    <div class="container thanks__inner">
      <span class="eyebrow" data-reveal="up">WAMOCON</span>
      <h1 data-reveal="up" data-reveal-delay="60">Thank you!</h1>
      <p class="text-muted" data-reveal="up" data-reveal-delay="120">
        We have received your message. We will get back to you as soon as possible –
        usually within 48 hours.
      </p>
      <div data-reveal="up" data-reveal-delay="180">
        <Button href="/en/" variant="primary" size="lg">Back to home</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .thanks {
    min-height: 60vh;
    display: grid;
    place-items: center;
    text-align: center;
  }
  .thanks__inner {
    max-width: 640px;
  }
  .thanks h1 {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    margin-bottom: 1.25rem;
  }
  .thanks p {
    margin-bottom: 2rem;
    font-size: 1.15rem;
  }
</style>
