</style>

<script>
  function initLeadModals() {
    const modals = document.querySelectorAll<HTMLElement>('[data-modal]');
    if (!modals.length) return;

    const open = (modal: HTMLElement) => {
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };
    const close = (modal: HTMLElement) => {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    document.querySelectorAll<HTMLElement>('[data-modal-open]').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const target = document.getElementById(trigger.dataset.modalOpen ?? '');
        if (target) open(target);
      });
    });

    modals.forEach((modal) => {
      modal.querySelectorAll<HTMLElement>('[data-modal-close]').forEach((btn) => {
        btn.addEventListener('click', () => close(modal));
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        modals.forEach((modal) => {
          if (modal.classList.contains('is-open')) close(modal);
        });
      }
    });
  }

  initLeadModals();
  document.addEventListener('astro:after-swap', initLeadModals);
</script>
