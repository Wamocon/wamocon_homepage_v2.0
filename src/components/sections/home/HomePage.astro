---
/**
 * Home page composition. All content comes from src/data/home.ts and
 * src/data/apps.ts so it stays identical across languages — only `lang` differs.
 */
import Button from '../../ui/Button.astro';
import { home } from '../../../data/home';
import { nav, ui, legalNav, type Lang } from '../../../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = (k: keyof (typeof ui)['de']) => ui[lang][k];
const aboutHref = nav.find((n) => n.key === 'about')![lang].href;
const privacyHref = legalNav.privacy[lang].href;

// Split a heading so the first N words can be highlighted in CI red.
const splitFirst = (s: string, n = 1) => {
  const first = s.split(' ').slice(0, n).join(' ');
  return { first, rest: s.slice(first.length) };
};
// Split a heading so the last word can be highlighted in CI red.
const splitLast = (s: string) => {
  const idx = s.lastIndexOf(' ');
  return { head: s.slice(0, idx), last: s.slice(idx) };
};

const aboutHeading = splitFirst(home.about.heading[lang]);
const benefitsHeading = splitFirst(home.benefits.heading[lang]);
const projectsHeading = splitLast(home.projects.heading[lang]);
const academyHeading = splitFirst(home.academy.heading[lang], 2);
const projectCompanyLabel = lang === 'de' ? 'Über das Unternehmen' : 'About the company';
const projectProjectLabel = lang === 'de' ? 'Über das Projekt' : 'About the project';
const ceoCaption =
  lang === 'de'
    ? 'Waleri Moretz, Visionär und CEO der WAMOCON'
    : 'Waleri Moretz, Visionary and CEO of WAMOCON';

// Lead-capture popup copy (opened from the "Erfahren Sie mehr" CTA).
const modal = {
  de: {
    title: 'Erfahren Sie mehr über die Auswahl von IT-Testern',
    subtitle: 'Hinterlassen Sie Ihre Kontakte, unter denen wir Sie kontaktieren können',
    name: 'Ihr Name',
    phone: 'Telefon',
    email: 'E-Mail',
    comment: 'Kommentare/Link zur Datei',
    consentPre: 'Hiermit bestätige ich, dass ich die ',
    consentLink: 'Datenschutzerklärung',
    consentPost:
      ' gelesen habe und damit einverstanden bin, dass die WAMOCON GmbH meine Daten, einschließlich personenbezogener Daten, speichern und verarbeiten darf.',
    submit: 'Anfrage senden',
    close: 'Schließen',
  },
  en: {
    title: 'Learn more about selecting IT testers',
    subtitle: 'Leave your contact details and we will get in touch with you',
    name: 'Your name',
    phone: 'Phone',
    email: 'Email',
    comment: 'Comments/link to file',
    consentPre: 'I hereby confirm that I have read the ',
    consentLink: 'privacy policy',
    consentPost:
      ' and agree that WAMOCON GmbH may store and process my data, including personal data.',
    submit: 'Send request',
    close: 'Close',
  },
}[lang];
---

<!-- ============ HERO ============ -->
<section class="hero">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="hero__visual" data-reveal="zoom" data-reveal-delay="150">
    <img
      src="/images/hero-block-back.png"
      alt=""
      width="900"
      height="900"
      class="hero__img hero__img--back"
      loading="eager"
      aria-hidden="true"
    />
    <img
      src="/images/hero-block-front.png"
      alt=""
      width="900"
      height="900"
      fetchpriority="high"
      class="hero__img hero__img--front"
    />
  </div>
  <div class="hero__inner">
    <div class="hero__content">
      <h1 class="hero__title" data-reveal="up">{home.hero.title}</h1>
      <p class="hero__tagline" data-reveal="up" data-reveal-delay="100">
        {home.hero.tagline[lang]}
      </p>
      <ul class="hero__stats" data-reveal="up" data-reveal-delay="200">
        {
          home.hero.stats.map((s) => (
            <li class="hero__stat">
              <span class="hero__stat-value">{s.value}</span>
              <span class="hero__stat-label">{s.label[lang]}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<!-- ============ GOAL ============ -->
<section class="section goal">
  <div class="container goal__inner">
    <figure class="goal__media" data-reveal="left">
      <img src="/images/goal-ceo.png" alt={ceoCaption} width="560" height="640" loading="lazy" />
      <figcaption>{ceoCaption}</figcaption>
    </figure>
    <div class="goal__text" data-reveal="right">
      <span class="eyebrow">{home.goal.signoff[lang].split(',')[0]}</span>
      <h2>{home.goal.heading[lang]}</h2>
      <p class="goal__lead">{home.goal.text[lang]}</p>
      <h3 class="goal__highlight">{home.goal.highlightTitle[lang]}</h3>
      <p class="text-muted">{home.goal.highlightText[lang]}</p>
      <p class="goal__signoff">{home.goal.signoff[lang]}</p>
      <div class="goal__badges">
        <img src="/images/badge-ki-siegel.png" alt="KI-Siegel WAMOCON" width="120" height="120" loading="lazy" />
        <img class="goal__badge--zukunft" src="/images/badge-zukunft.webp" alt="Unternehmen der Zukunft – nominiert" width="135" height="120" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- ============ SERVICES ============ -->
<section class="section services">
  <div class="services__wave" aria-hidden="true">
    <img src="/images/red-wave-1.svg" alt="" loading="lazy" />
  </div>
  <div class="container">
    <div class="section-head" data-reveal="up">
      <h2>{home.services.heading[lang]}</h2>
      <p class="text-muted">{home.services.intro[lang]}</p>
    </div>
    <div class="services__grid">
      {
        home.services.items.map((item, i) => (
          <article class="service-card" data-reveal="up" data-reveal-delay={(i % 3) * 80}>
            <span class="service-card__num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{item.title[lang]}</h3>
            <p class="text-muted">{item.text[lang]}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<!-- ============ QUALITY ASSURANCE ============ -->
<section class="section qa">
  <div class="container qa__inner">
    <div class="qa__text" data-reveal="left">
      <h2>{home.qa.heading[lang]}</h2>
      <p class="text-muted">{home.qa.text[lang]}</p>
      <h4 class="qa__list-title">{home.qa.listTitle[lang]}</h4>
      <ul class="qa__list">
        {home.qa.list[lang].map((li) => <li>{li}</li>)}
      </ul>
      <p class="text-muted">{home.qa.closing[lang]}</p>
      <Button variant="primary" data-modal-open="it-tester">{home.qa.cta[lang]}</Button>
    </div>
    <div class="qa__video" data-reveal="right">
      <div class="video-frame">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${home.qa.youtubeId}`}
          title="WAMOCON"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</section>

<!-- ============ LEAD CAPTURE MODAL ============ -->
<div class="lead-modal" id="it-tester" data-modal aria-hidden="true">
  <div class="lead-modal__overlay" data-modal-close></div>
  <div class="lead-modal__panel" role="dialog" aria-modal="true" aria-labelledby="it-tester-title">
    <button type="button" class="lead-modal__close" data-modal-close aria-label={modal.close}>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>
    <h2 class="lead-modal__title" id="it-tester-title">{modal.title}</h2>
    <p class="lead-modal__subtitle">{modal.subtitle}</p>
    <form class="lead-modal__form js-lead-form" data-redirect={lang === "de" ? "/danke/" : "/en/thank-you/"}>
      <input type="hidden" name="type" value="it-tester" />
      <input type="hidden" name="lang" value={lang} />
      <input type="text" name="name" placeholder={modal.name} required />
      <input type="tel" name="phone" placeholder={modal.phone} required />
      <input type="email" name="email" placeholder={modal.email} required />
      <textarea name="comment" rows="3" placeholder={modal.comment}></textarea>
      <label class="lead-modal__consent">
        <input type="checkbox" name="consent" required />
        <span>
          {modal.consentPre}<a href={privacyHref}>{modal.consentLink}</a>{modal.consentPost}
        </span>
      </label>
      <button type="submit" class="btn btn--primary lead-modal__submit">{modal.submit}</button>
    </form>
  </div>
</div>


<!-- ============ WHY WAMOCON ============ -->
<section class="section why">
  <div class="container">
    <div class="section-head" data-reveal="up">
      <h2>{home.why.heading[lang]}</h2>
      <p class="text-muted">{home.why.intro[lang]}</p>
    </div>
    <div class="why__grid">
      {
        home.why.points.map((p, i) => (
          <article class="why-card" data-reveal="up" data-reveal-delay={(i % 4) * 70}>
            <span class="why-card__num">{p.num}/</span>
            <p>{p.text[lang]}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<!-- ============ ABOUT ============ -->
<section class="section about">
  <div class="container about__inner">
    <h2 class="about__heading" data-reveal="up">
      <span class="about__heading-accent">{aboutHeading.first}</span>{aboutHeading.rest}
    </h2>
    <div class="about__grid">
      <div class="about__cols" data-reveal="left">
        {home.about.paragraphs[lang].map((p) => <p class="text-muted">{p}</p>)}
      </div>
      <figure class="about__media" data-reveal="right">
        <img
          src="/images/about-skyline.jpg"
          alt="Frankfurt Skyline"
          width="720"
          height="540"
          loading="lazy"
        />
      </figure>
    </div>
  </div>
</section>

<!-- ============ BENEFITS ============ -->
<section class="section benefits">
  <div class="container">
    <div class="section-head" data-reveal="up">
      <h2><span class="accent">{benefitsHeading.first}</span>{benefitsHeading.rest}</h2>
    </div>
    <div class="benefits__grid">
      {
        home.benefits.items.map((b, i) => (
          <article class="benefit-card" data-reveal="up" data-reveal-delay={(i % 3) * 80}>
            <h3>{b.title[lang]}</h3>
            <p class="text-muted">{b.text[lang]}</p>
          </article>
        ))
      }
    </div>
    <div class="benefits__cta" data-reveal="up">
      <Button href={aboutHref} variant="primary" size="lg">{home.benefits.cta[lang]}</Button>
    </div>
  </div>
</section>

<!-- ============ PROJECTS ============ -->
<section class="section projects">
  <div class="container">
    <div class="section-head" data-reveal="up">
      <h2>{projectsHeading.head}<span class="accent"> {projectsHeading.last.trim()}</span></h2>
    </div>
    <div class="projects__grid">
      {
        home.projects.items.map((p, i) => (
          <article class="project-card" data-reveal="up" data-reveal-delay={i * 90}>
            <span class="project-card__index">0{i + 1}</span>
            <h3>{p.title[lang]}</h3>
            <p class="project-card__client">{p.client}</p>
            <button type="button" class="project-card__btn" data-modal-open={`project-${i}`}>
              {home.projects.cta[lang]}
            </button>
          </article>
        ))
      }
    </div>
  </div>
</section>

<!-- ============ PROJECT MODALS ============ -->
{
  home.projects.items.map((p, i) => (
    <div class="lead-modal project-modal" id={`project-${i}`} data-modal aria-hidden="true">
      <div class="lead-modal__overlay" data-modal-close />
      <div class="lead-modal__panel project-modal__panel" role="dialog" aria-modal="true" aria-labelledby={`project-${i}-title`}>
        <button type="button" class="lead-modal__close" data-modal-close aria-label={modal.close}>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </button>
        <h2 class="project-modal__title" id={`project-${i}-title`}>{p.popupTitle[lang]}</h2>
        <h3 class="project-modal__label">{projectCompanyLabel}</h3>
        <p class="project-modal__text">{p.company[lang]}</p>
        <h3 class="project-modal__label">{projectProjectLabel}</h3>
        <p class="project-modal__text">{p.project[lang]}</p>
      </div>
    </div>
  ))
}

<!-- ============ CLIENTS ============ -->
<section class="section clients">
  <div class="container">
    <div class="section-head" data-reveal="up">
      <h2>{home.clients.heading[lang]}</h2>
    </div>
    <ul class="clients__list" data-reveal="up">
      {home.clients.list.map((c) => <li class="clients__item">{c}</li>)}
    </ul>
  </div>
</section>

<!-- ============ EDUCATION CENTER ============ -->
<section class="section education">
  <div class="container education__inner">
    <div class="education__text" data-reveal="left">
      <h2>{home.education.heading[lang]}</h2>
      {home.education.paragraphs[lang].map((p) => <p class="text-muted">{p}</p>)}
    </div>
    <div class="education__video" data-reveal="right">
      <div class="video-frame">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${home.education.youtubeId}`}
          title={home.education.heading[lang]}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</section>

<!-- ============ ACADEMY CTA ============ -->
<section class="section academy">
  <div class="container academy__card" data-reveal="zoom">
    <h2><span class="accent">{academyHeading.first}</span>{academyHeading.rest}</h2>
    <div class="academy__rows">
      {
        home.academy.pairs.map((p) => (
          <div class="academy__row">
            <h3 class="academy__row-title">{p.title[lang]}</h3>
            <p class="academy__row-text">{p.text[lang]}</p>
          </div>
        ))
      }
    </div>
    <Button href={home.academy.ctaUrl} target="_blank" variant="primary" size="lg">
      {home.academy.cta[lang]}
    </Button>
  </div>
</section>

<!-- ============ 360 OFFICE TOUR ============ -->
<section class="section tour">
  <div class="container">
    <div class="tour__text" data-reveal="up">
      <span class="tour__badge">360°</span>
      <h2>{home.tour.heading[lang]}</h2>
      <p class="text-muted">{home.tour.text[lang]}</p>
    </div>
    <div class="tour__view" data-reveal="zoom">
      <iframe
        src={home.tour.embedUrl}
        title={home.tour.heading[lang]}
        loading="lazy"
        allowfullscreen
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
    <div class="tour__cta" data-reveal="up">
      <Button href={home.tour.mapsUrl} target="_blank" variant="outline" size="lg">
        {home.tour.cta[lang]}
      </Button>
    </div>
  </div>
</section>

<style>
  /* ---------- shared ---------- */
  .section-head {
    max-width: 760px;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .section-head h2 {
    margin-bottom: 1rem;
  }
  .accent {
    color: var(--color-accent);
  }
  .video-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    background: #000;
  }
  .video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .video-frame img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ---------- hero ---------- */
  .hero {
    position: relative;
    overflow-x: clip;
    min-height: min(92vh, 880px);
    display: flex;
    align-items: center;
  }
  .hero__glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 50% at 75% 35%, var(--glow-top), transparent 70%),
      radial-gradient(40% 40% at 100% 60%, var(--glow-side), transparent 70%);
    pointer-events: none;
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
  }
  .hero__content {
    max-width: 620px;
  }
  .hero__title {
    font-size: clamp(3.2rem, 11vw, 8rem);
    letter-spacing: 0.02em;
    line-height: 1;
  }
  .hero__tagline {
    max-width: 44ch;
    margin-top: 1.5rem;
    font-size: clamp(1.05rem, 2vw, 1.5rem);
    color: var(--color-text-muted);
  }
  .hero__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem 2rem;
    margin-top: clamp(2rem, 4vw, 3rem);
    max-width: 760px;
  }
  .hero__stat-value {
    display: block;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--fw-bold);
    color: var(--color-accent-2);
    line-height: 1;
  }
  .hero__stat-label {
    display: block;
    margin-top: 0.4rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }
  .hero__visual {
    position: absolute;
    top: 58%;
    right: -4%;
    transform: translateY(-50%);
    z-index: 1;
    width: 70vw;
    max-width: 1240px;
    aspect-ratio: 1 / 1;
    pointer-events: none;
  }
  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: auto;
  }
  .hero__img--back {
    opacity: 0.45;
    filter: drop-shadow(0 20px 50px rgba(0, 0, 0, 0.5)) saturate(0.7) blur(6px);
    animation: float-back 7s ease-in-out infinite;
  }
  .hero__img--front {
    filter: drop-shadow(0 30px 80px rgba(244, 14, 14, 0.35));
    animation: float 6s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-18px) rotate(-1.5deg); }
  }
  @keyframes float-back {
    0%, 100% { transform: translate(-18%, -14%) scale(0.92) rotate(180deg); }
    50% { transform: translate(-18%, calc(-14% - 16px)) scale(0.92) rotate(180deg); }
  }

  /* ---------- goal ---------- */
  .goal__inner {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .goal__media {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-subtle);
  }
  .goal__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 7 / 8;
  }
  .goal__media figcaption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 1.25rem 1.5rem;
    font-size: 0.95rem;
    color: #fff;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.75));
  }
  .goal__lead {
    margin: 1.5rem 0;
    font-size: 1.15rem;
  }
  .goal__highlight {
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }
  .goal__signoff {
    margin-top: 1.5rem;
    font-weight: var(--fw-semibold);
  }
  .goal__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    margin-top: 2rem;
  }
  .goal__badges img {
    height: 110px;
    width: auto;
    object-fit: contain;
  }
  .goal__badges img.goal__badge--zukunft {
    height: 117px;
  }

  /* ---------- services / why / benefits grids ---------- */
  .services {
    position: relative;
    overflow: hidden;
  }
  .services__wave {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .services__wave img {
    width: 120%;
    max-width: none;
    height: auto;
    opacity: 0.55;
    filter: saturate(1.1) drop-shadow(0 0 40px rgba(244, 14, 14, 0.35));
  }
  .services .container {
    position: relative;
    z-index: 1;
  }
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .benefits__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .service-card,
  .benefit-card {
    padding: 2rem;
    background: var(--surface-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    transition: transform var(--dur-med) var(--ease-out), border-color var(--dur-med);
  }
  .service-card:hover,
  .benefit-card:hover {
    transform: translateY(-6px);
    border-color: rgba(244, 14, 14, 0.4);
  }
  .service-card__num {
    display: inline-block;
    font-size: 1.5rem;
    font-weight: var(--fw-bold);
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }
  .service-card h3,
  .benefit-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }

  /* ---------- QA / education two-column ---------- */
  .qa__inner,
  .education__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .qa__list-title {
    margin: 1.5rem 0 0.75rem;
    color: var(--color-accent);
  }
  .qa__list {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .qa__list li {
    position: relative;
    padding-left: 1.75rem;
  }
  .qa__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--color-accent);
  }
  .qa__text p { margin-bottom: 1rem; }
  .education__text h2 { margin-bottom: 1.5rem; }
  .education__text p { margin-bottom: 1rem; }

  /* ---------- why ---------- */
