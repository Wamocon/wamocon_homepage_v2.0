    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.55);
    transform: translateY(24px) scale(0.98);
    transition: transform var(--dur-med) var(--ease-out);
