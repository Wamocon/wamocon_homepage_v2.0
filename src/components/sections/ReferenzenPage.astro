---
/** Referenzen / References page — displays client list and company info images. */
import type { Lang } from '../../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const de = lang === 'de';

const c = de
  ? {
      title: 'Referenzen',
      heading: 'Wer sind unsere Kunden?',
      lead: 'Unsere Kunden vertrauen auf die Expertise der WAMOCON GmbH.',
      contactHeading: 'Kontakt',
      imgCustomersAlt: 'Übersicht ausgewählter WAMOCON Kunden',
      imgContactAlt: 'WAMOCON Büro und Kontaktdaten',
    }
  : {
      title: 'References',
      heading: 'Who are our customers?',
      lead: 'Our customers trust the expertise of WAMOCON GmbH.',
      contactHeading: 'Contact',
      imgCustomersAlt: 'Overview of selected WAMOCON customers',
      imgContactAlt: 'WAMOCON office and contact details',
    };
---

<section class="ref-hero">
  <div class="container">
    <h1 class="ref-hero__title">{c.heading}</h1>
    <p class="ref-hero__lead">{c.lead}</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="ref-image" data-reveal="up">
      <img
        src="/images/referenzen-kunden.svg"
        alt={c.imgCustomersAlt}
        loading="lazy"
        width="1600"
        height="900"
      />
    </div>
  </div>
</section>

<section class="section section--alt">
  <div class="container">
    <div class="ref-image" data-reveal="up">
      <img
        src="/images/referenzen-kontakt.svg"
        alt={c.imgContactAlt}
        loading="lazy"
        width="1600"
        height="900"
      />
    </div>
  </div>
</section>

<style>
  .ref-hero {
    padding: clamp(3rem, 8vw, 6rem) 0 clamp(1.5rem, 4vw, 3rem);
    text-align: center;
  }
  .ref-hero__title {
    font-size: clamp(2rem, 5.5vw, 3.6rem);
    font-weight: var(--fw-bold);
    line-height: 1.08;
    margin-bottom: 1.2rem;
  }
  .ref-hero__lead {
    max-width: 820px;
    margin: 0 auto;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .ref-image {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
  }
  .ref-image img {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
