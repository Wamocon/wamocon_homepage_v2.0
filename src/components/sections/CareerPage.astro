---

<section class="career">
  <!-- HERO -->
  <div class="wrap hero">
    <div class="hero-text">
      <h1><span class="t-red">{c.heroTitleRed}</span> <span class="t-white">{c.heroTitleWhite}</span></h1>
      {c.heroText.map((p) => <p>{p}</p>)}
      <a href="#stellenangebote" class="btn">{c.heroBtn}</a>
    </div>
    <div class="hero-img">
      <img src="/images/career-hero.png" alt="WAMOCON Team" width="1680" height="945" loading="lazy" />
    </div>
  </div>

  <!-- ERFOLG MIT SYSTEM -->
  <div class="wrap">
    <h2 class="head"><span class="t-red">{c.systemHeadRed}</span> <span class="t-white">{c.systemHeadWhite}</span></h2>
    <p class="lead">{c.systemIntro}</p>
    <div class="grid3">
      {c.systemCards.map((card) => (
        <article class="card">
          <h3>{card.t}</h3>
          <p>{card.d}</p>
        </article>
      ))}
    </div>
    <p class="lead">{c.systemClose}</p>
  </div>

  <!-- BENEFITS -->
  <div class="wrap">
    <h2 class="head"><span class="t-red">{c.benefitsHeadRed}</span> <span class="t-white">{c.benefitsHeadWhite}</span></h2>
    <div class="grid3">
      {c.benefits.map((b) => (
        <article class="card">
          <h3>{b.t}</h3>
          <p>{b.d}</p>
        </article>
      ))}
    </div>
  </div>

  <!-- JOIN -->
  <div class="wrap">
    <h2 class="head"><span class="t-red">{c.joinHeadRed}</span> <span class="t-white">{c.joinHeadWhite}</span></h2>
    {c.joinText.map((p) => <p class="lead">{p}</p>)}
  </div>

  <!-- STELLENANGEBOTE -->
  <div class="wrap" id="stellenangebote">
    <h2 class="head"><span class="t-white">{c.jobsHead}</span></h2>
    <div class="jobs">
      {jobs.map((job, ji) => (
        <article class="job">
          <button class="job-head" data-job={ji} aria-expanded="false">
            <span>{job.title}</span>
            <span class="chev">+</span>
          </button>
          <div class="job-body" hidden>
            <div class="job-tabs" role="tablist">
              {c.tabs.map((tab, ti) => (
                <button class={`tab${ti === 0 ? " active" : ""}`} data-job={ji} data-tab={ti}>{tab}</button>
              ))}
            </div>
            <div class="tab-panels">
              <div class="panel active" data-job={ji} data-panel="0">
                <p>{job.short}</p>
              </div>
              <div class="panel" data-job={ji} data-panel="1">
                <ul>{job.tasks.map((x) => <li>{x}</li>)}</ul>
              </div>
              <div class="panel" data-job={ji} data-panel="2">
                <ul>{job.req.map((x) => <li>{x}</li>)}</ul>
              </div>
              <div class="panel" data-job={ji} data-panel="3">
                <ul>{job.offer.map((x) => <li>{x}</li>)}</ul>
              </div>
            </div>
            <a href="#bewerbung" class="btn">{c.applyBtn}</a>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- VOICES -->
  <div class="wrap">
    <h2 class="head"><span class="t-white">{c.voicesHead}</span></h2>
    <div class="grid4">
      {c.voices.map((v, vi) => (
        <article class="voice">
          <div class="voice__img">
            <img src={v.img} alt={v.author} loading="lazy" />
          </div>
          <div class="voice__body">
            <h3>{v.t}</h3>
            <p class="voice__quote">&bdquo;{v.q}&ldquo;</p>
            <button type="button" class="voice__more" data-voice-open={vi}>
              {de ? "Mehr lesen" : "Read more"}
            </button>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- VOICE POPUPS -->
  {c.voices.map((v, vi) => (
    <div class="vpopup" id={`vpopup-${vi}`} data-voice-panel={vi} hidden>
      <div class="vpopup__overlay" data-voice-close></div>
      <div class="vpopup__box" role="dialog" aria-modal="true" aria-labelledby={`vpopup-title-${vi}`}>
        <button type="button" class="vpopup__close" data-voice-close aria-label={de ? "Schließen" : "Close"}>×</button>
        <div class="vpopup__head">
          <img class="vpopup__avatar" src={v.img} alt={v.author} loading="lazy" />
          <div>
            <strong class="vpopup__author">{v.author}</strong>
            <span class="vpopup__role">{v.role}</span>
          </div>
        </div>
        <h3 class="vpopup__title" id={`vpopup-title-${vi}`}>{v.popupTitle}</h3>
        {v.full.map((block) => (
          block.type === "h" ? <h4 class="vpopup__sub">{block.text}</h4>
          : block.type === "ul" ? <ul class="vpopup__list">{block.items?.map((it) => <li>{it}</li>)}</ul>
          : block.type === "quote" ? <p class="vpopup__quote">{block.text}</p>
          : <p>{block.text}</p>
        ))}
      </div>
    </div>
  ))}

  <!-- KUNUNU -->
  <div class="wrap">
    <h2 class="head"><span class="t-white">{c.kununuHead}</span></h2>
    <div class="grid3 kununu">
      {kununu.map((k) => (
        <article class="kcard">
          <div class="krate">★ {k.r}</div>
          <h3 class="t-white">{k.t}</h3>
          <p class="kmeta">{k.d} · {k.role}</p>
        </article>
      ))}
    </div>
    <div class="center">
      <a href="https://www.kununu.com/de/wamocon/kommentare" target="_blank" rel="noopener" class="btn">{c.kununuBtn}</a>
    </div>
  </div>

  <!-- TEAM VIDEOS -->
  <div class="wrap">
    <h2 class="head"><span class="t-white">{c.teamVideoHead}</span></h2>
    <div class="grid3">
      {videos.map((v) => (
        <article class="vidcard">
          <video controls preload="metadata" playsinline poster={v.poster}>
            <source src={v.src} type="video/mp4" />
          </video>
          <h3>{v.name}</h3>
        </article>
      ))}
    </div>
  </div>

  <!-- BEWERBUNGSFORMULAR -->
  <div class="wrap form-wrap" id="bewerbung">
    <div class="form-img">
      <img src="/images/career-member.jpg" alt="WAMOCON" loading="lazy" />
    </div>
    <div class="form-box">
      <h2 class="head"><span class="t-red">{c.formHeadRed}</span> <span class="t-white">{c.formHeadWhite}</span></h2>
