        <input type="hidden" name="type" value="career" />
        <input type="hidden" name="lang" value={lang} />
        <input type="text" name="name" placeholder={c.formName} required />
        <input type="tel" name="phone" placeholder={c.formPhone} required />
        <input type="email" name="email" placeholder={c.formEmail} required />
        <textarea name="comment" placeholder={c.formComment} rows="4" required></textarea>
        <label class="consent">
          <input type="checkbox" name="consent" required />
          <span>{c.formConsent} <a href={c.formConsentHref}>{c.formConsentLink}</a>{c.formConsentPost}</span>
        </label>
        <button type="submit" class="btn">{c.formBtn}</button>
      </form>
      <p class="form-close">{c.formClose}</p>
    </div>
  </div>

