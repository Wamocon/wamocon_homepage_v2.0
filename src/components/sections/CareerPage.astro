<script>
  function setupCareer() {
    document.querySelectorAll<HTMLButtonElement>(".job-head").forEach((head) => {
      head.addEventListener("click", () => {
        const body = head.nextElementSibling as HTMLElement | null;
        if (!body) return;
        const open = head.getAttribute("aria-expanded") === "true";
        head.setAttribute("aria-expanded", String(!open));
        body.hidden = open;
        const chev = head.querySelector(".chev");
        if (chev) chev.textContent = open ? "+" : "−";
      });
    });

    document.querySelectorAll<HTMLButtonElement>(".tab").forEach((tab) => {
      tab.addEventListener("click", () => {
        const job = tab.dataset.job;
        const idx = tab.dataset.tab;
        document
          .querySelectorAll<HTMLElement>(`.tab[data-job="${job}"]`)
          .forEach((t) => t.classList.remove("active"));
        tab.classList.add("active");
        document
          .querySelectorAll<HTMLElement>(`.panel[data-job="${job}"]`)
          .forEach((p) => p.classList.remove("active"));
        const panel = document.querySelector<HTMLElement>(
          `.panel[data-job="${job}"][data-panel="${idx}"]`
        );
        if (panel) panel.classList.add("active");
      });
    });

    // Employee-voice "read more" popups
    const openVoice = (idx: string) => {
      const panel = document.querySelector<HTMLElement>(
        `.vpopup[data-voice-panel="${idx}"]`
      );
      if (!panel) return;
      panel.hidden = false;
      document.body.classList.add("vpopup-open");
    };
    const closeVoices = () => {
      document
        .querySelectorAll<HTMLElement>(".vpopup")
        .forEach((p) => (p.hidden = true));
      document.body.classList.remove("vpopup-open");
    };

    document
      .querySelectorAll<HTMLButtonElement>("[data-voice-open]")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const idx = btn.getAttribute("data-voice-open");
          if (idx !== null) openVoice(idx);
        });
      });
    document
      .querySelectorAll<HTMLElement>("[data-voice-close]")
      .forEach((el) => el.addEventListener("click", closeVoices));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeVoices();
    });
  }

  setupCareer();
  document.addEventListener("astro:after-swap", setupCareer);
</script>
