---

<section class="voices">
  <div class="wrap hero">
    <img class="hero-shape" src="/images/testimonials-shape.png" alt="" aria-hidden="true" loading="lazy" />
    <h1><span class="t-red">{heroTitle}</span></h1>
    <p class="lead">{heroLead}</p>
  </div>

  {members.map((m, mi) => (
    <div class="wrap member">
      <div class="member-head">
        <img src={m.img} alt={m.name} class="avatar" loading="lazy" />
        <div>
          <h2 class="t-white">{m.name}</h2>
          <ul class="bio">{m.bio.map((b) => <li>{b}</li>)}</ul>
        </div>
      </div>

      <div class="tabs" role="tablist">
        {m.videos.map((v, vi) => (
          <button class={`tab${vi === 0 ? " active" : ""}`} data-member={mi} data-video={vi}>{v.tab}</button>
        ))}
      </div>

      <div class="panels">
        {m.videos.map((v, vi) => (
          <div class={`panel${vi === 0 ? " active" : ""}`} data-member={mi} data-video={vi}>
            <div class="video">
              <iframe
                loading="lazy"
                src={`https://www.youtube-nocookie.com/embed/${v.id}`}
                title={v.title}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
            <div class="video-text">
              <h3 class="t-red">{v.title}</h3>
              <p>{v.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}

  <ContactBlock lang={lang} />
</section>

<style>
  .voices {
    color: var(--color-text);
  }
  .wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 4rem) 1.25rem;
  }
  .t-red {
    color: var(--color-accent);
  }
  .t-white {
    color: #fff;
  }
  .hero {
    position: relative;
    text-align: center;
  }
  .hero-shape {
    position: absolute;
    top: 50%;
    right: clamp(-40px, 0vw, 20px);
    transform: translateY(-50%);
    width: clamp(150px, 18vw, 280px);
    height: auto;
    pointer-events: none;
    z-index: 0;
    will-change: transform;
    animation: ev-float 6s ease-in-out infinite;
  }
  .hero h1,
  .hero .lead {
    position: relative;
    z-index: 1;
  }
  @keyframes ev-float {
    0% { transform: translateY(-50%) scale(1) rotate(0deg); }
    50% { transform: translateY(calc(-50% - 16px)) scale(1.04) rotate(-4deg); }
    100% { transform: translateY(-50%) scale(1) rotate(0deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-shape { animation: none; }
  }
  @media (max-width: 700px) {
    .hero-shape { opacity: 0.22; right: -30px; }
  }
  h1 {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    margin: 0 0 1rem;
    font-weight: var(--fw-bold);
  }
  .lead {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    line-height: 1.7;
    margin: 0 auto;
    max-width: 60ch;
  }
  .member {
    border-top: 1px solid var(--border-subtle);
  }
  .member-head {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.75rem;
  }
  .avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-accent);
    flex-shrink: 0;
  }
  .member-head h2 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    margin: 0 0 0.75rem;
  }
  .bio {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
  .bio li {
    margin-bottom: 0.3rem;
  }
  .tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .tab {
    padding: 0.6rem 1.2rem;
    background: transparent;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 0.95rem;
    transition: all var(--dur-fast) var(--ease-out);
  }
  .tab.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }
  .panel {
    display: none;
    grid-template-columns: 1.3fr 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }
  .panel.active {
    display: grid;
  }
  .video {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-subtle);
  }
  .video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .video-text h3 {
    font-size: 1.3rem;
    margin: 0 0 1rem;
    line-height: 1.3;
  }
  .video-text p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }
  @media (max-width: 800px) {
    .panel.active {
      grid-template-columns: 1fr;
    }
    .member-head {
      flex-direction: column;
      text-align: center;
      align-items: center;
    }
    .bio {
      text-align: left;
    }
  }
</style>

<script>
  function setupVoices() {
    document.querySelectorAll<HTMLButtonElement>(".voices .tab").forEach((tab) => {
      tab.addEventListener("click", () => {
        const m = tab.dataset.member;
        const v = tab.dataset.video;
        document
          .querySelectorAll<HTMLElement>(`.voices .tab[data-member="${m}"]`)
          .forEach((t) => t.classList.remove("active"));
        tab.classList.add("active");
        document
          .querySelectorAll<HTMLElement>(`.voices .panel[data-member="${m}"]`)
          .forEach((p) => p.classList.remove("active"));
        const panel = document.querySelector<HTMLElement>(
          `.voices .panel[data-member="${m}"][data-video="${v}"]`
        );
        if (panel) panel.classList.add("active");
      });
    });
  }

  setupVoices();
  document.addEventListener("astro:after-swap", setupVoices);
</script>
