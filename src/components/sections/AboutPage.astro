<!-- HERO -->
<section class="ab-hero">
  <div class="container">
    <h1 class="ab-hero__title">{c.heroTitle}</h1>
    <div class="ab-hero__grid">
      <div class="ab-hero__block" data-reveal="up">
        <strong>{c.heroBlocks[0].h}</strong>
        <p>{c.heroBlocks[0].p}</p>
      </div>
      <img class="ab-hero__img" src="/images/team-photo.jpg" alt="WAMOCON" loading="lazy" />
      <div class="ab-hero__block" data-reveal="up" data-reveal-delay="80">
        <strong>{c.heroBlocks[1].h}</strong>
        <p>{c.heroBlocks[1].p}</p>
      </div>
      <div class="ab-hero__block" data-reveal="up" data-reveal-delay="160">
        <strong>{c.heroBlocks[2].h}</strong>
        <p>{c.heroBlocks[2].p}</p>
      </div>
    </div>
  </div>
</section>

<!-- SUCCESS FACTORS -->
<section class="section section--alt">
  <div class="container">
    <h2 class="ab-h2"><span class="t-red">{c.factorsLead}</span><span class="t-white">{c.factorsRest}</span></h2>
    <ul class="ab-factors">
      {c.factors.map((f, i) => (
        <li class="ab-factor" data-reveal="up" data-reveal-delay={i * 50}>
          <strong>{f.h}</strong>
          <span>{f.p}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<!-- GUIDE -->
<section class="section">
  <div class="container">
    <h2 class="ab-h2"><span class="t-red">{c.guideLead}</span><span class="t-white">{c.guideRest}</span></h2>
    <div class="ab-guide">
      {c.guideCards.map((card, i) => (
        <article class="ab-guide__card" data-reveal="up" data-reveal-delay={i * 80}>
          <h3>{card.h}</h3>
          <ul>
            {card.items.map((it) => <li>{it}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- SOLUTION -->
<section class="section section--alt">
  <div class="container">
    <h2 class="ab-h2"><span class="t-white">{c.solutionLead}</span><span class="t-white">{c.solutionMid}</span><span class="t-red">{c.solutionAccent}</span></h2>
    <div class="ab-solution">
      {c.solutionParas.map((sp, i) => (
        <div class="ab-solution__col" data-reveal="up" data-reveal-delay={i * 80}>
          <strong>{sp.s}</strong>
          <p>{sp.p}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- VISION -->
<section class="section">
  <div class="container">
    <h2 class="ab-h2"><span class="t-white">{c.visionLead}</span><span class="t-red">{c.visionAccent}</span></h2>
    <div class="ab-vision">
      {c.visionItems.map((v, i) => (
        <article class="ab-vision__card" data-reveal="up" data-reveal-delay={i * 80}>
          <strong>{v.h}</strong>
          <p>{v.p}</p>
        </article>
      ))}
    </div>
  </div>
