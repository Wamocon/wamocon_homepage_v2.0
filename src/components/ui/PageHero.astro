---
/**
 * Reusable inner-page hero banner.
 * Props: eyebrow?, title, subtitle?, and an optional CTA (label + href).
 */
import Button from './Button.astro';
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaTarget?: string;
}
const { eyebrow, title, subtitle, ctaLabel, ctaHref, ctaTarget } = Astro.props;
---

<section class="page-hero">
  <div class="page-hero__glow" aria-hidden="true"></div>
  <div class="container page-hero__inner">
    {eyebrow && <span class="eyebrow" data-reveal="up">{eyebrow}</span>}
    <h1 data-reveal="up" data-reveal-delay="60">{title}</h1>
    {subtitle && <p class="page-hero__subtitle" data-reveal="up" data-reveal-delay="120" set:html={subtitle} />}
    {
      ctaLabel && ctaHref && (
        <div data-reveal="up" data-reveal-delay="180">
          <Button href={ctaHref} target={ctaTarget} variant="primary" size="lg">
            {ctaLabel}
          </Button>
        </div>
      )
    }
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3.5rem, 9vw, 7rem);
  }
  .page-hero__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(50% 60% at 70% 30%, var(--glow-top), transparent 70%);
    pointer-events: none;
  }
  .page-hero__inner {
    position: relative;
    max-width: 900px;
  }
  .page-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
  }
  .page-hero__subtitle {
    margin-top: 1.5rem;
    max-width: 60ch;
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    color: var(--color-text-muted);
  }
  .page-hero__inner > div {
    margin-top: 2rem;
  }
</style>
