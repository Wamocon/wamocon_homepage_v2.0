---
/** Reusable section heading block (centered or left aligned). */
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, text, align = 'left' } = Astro.props;
---

<div class:list={['section-heading', `section-heading--${align}`]} data-reveal="up">
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2>{title}</h2>
  {text && <p class="text-muted section-heading__text">{text}</p>}
</div>

<style>
  .section-heading {
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .section-heading--center {
    text-align: center;
    max-width: 760px;
    margin-inline: auto;
  }
  .section-heading--left {
    max-width: 820px;
  }
  .section-heading h2 {
    margin-bottom: 1rem;
  }
  .section-heading__text {
    font-size: 1.1rem;
  }
</style>
