---
/** Generic feature/benefit card: optional number or icon, title, text. */
interface Props {
  num?: string;
  title: string;
  text?: string;
  delay?: number;
}
const { num, title, text, delay = 0 } = Astro.props;
---

<article class="feature-card" data-reveal="up" data-reveal-delay={delay}>
  {num && <span class="feature-card__num">{num}</span>}
  <h3>{title}</h3>
  {text && <p class="text-muted">{text}</p>}
  <slot />
</article>

<style>
  .feature-card {
    padding: 2rem;
    background: var(--surface-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    transition: transform var(--dur-med) var(--ease-out), border-color var(--dur-med);
    height: 100%;
  }
  .feature-card:hover {
    transform: translateY(-6px);
    border-color: rgba(244, 14, 14, 0.4);
  }
  .feature-card__num {
    display: inline-block;
    font-size: 1.6rem;
    font-weight: var(--fw-bold);
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }
  .feature-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }
</style>
